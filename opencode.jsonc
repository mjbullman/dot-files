{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "model": "ollama/qwen3-coder:480b-cloud",
  "small_model": "ollama/gpt-oss:20b-cloud",
  "default_agent": "build",
  "autoupdate": "notify",
  "share": "manual",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "qwen3-coder:480b-cloud": {
          "name": "Qwen3 Coder 480B"
        },
        "llama3.1:8b": {
          "name": "Llama 3.1 8B"
        },
        "gpt-oss:20b-cloud": {
          "name": "GPT OSS 20B"
        },
        "gpt-oss:120b-cloud": {
          "name": "GPT OSS 120B"
        },
        "deepseek-v3.1:671b-cloud": {
          "name": "DeepSeek V3.1 671B"
        },
        "codellama:7b": {
          "name": "CodeLlama 7B"
        },
        "gemini-3-pro-preview:latest": {
          "name": "Gemini 3 Pro Preview"
        },
        "kimi-k2:1t-cloud": {
          "name": "Kimi K2 1T"
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "awk *": "allow",
      "jq *": "allow",
      "npm test*": "ask",
      "pnpm test*": "ask",
      "bun test*": "ask",
      "go test*": "ask",
      "pytest*": "ask",
      "cargo test*": "ask",
      "git push*": "deny",
      "rm *": "deny",
      "sudo *": "deny"
    },
    "webfetch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "command": {
    "tests": {
      "description": "Run full test suite and report failures",
      "agent": "build",
      "template": "Run the project tests. If failures occur, summarize root cause first, then propose minimal fixes."
    },
    "review": {
      "description": "Review local changes for bugs and regressions",
      "agent": "review",
      "template": "Review these local changes with a strict code-review mindset. Prioritize bugs, regressions, and missing tests.\n\n!`git diff`"
    },
    "commit": {
      "description": "Write a Conventional Commit for staged changes and commit",
      "agent": "build",
      "template": "Write a Conventional Commits message for the staged changes below, then run git commit with it. Do not stage anything new.\n\n!`git diff --cached`"
    },
    "explain": {
      "description": "Explain a file or path",
      "agent": "build",
      "template": "Explain @$1 — its purpose, key flows, and any risks or sharp edges."
    },
    "docs": {
      "description": "Sync AGENTS.md / CLAUDE.md with recent changes",
      "agent": "build",
      "template": "Update AGENTS.md and CLAUDE.md to reflect recent changes in this repo. Keep entries concise and consistent with the existing style."
    }
  },
  "agent": {
    "review": {
      "description": "Read-only reviewer focused on correctness and risk",
      "model": "ollama/qwen3-coder:480b-cloud",
      "prompt": "You are a rigorous code reviewer. Find correctness issues, regressions, and missing tests. Keep output concise and actionable.",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "Planning and design before coding — analyzes and proposes, asks before editing",
      "mode": "primary",
      "model": "ollama/deepseek-v3.1:671b-cloud",
      "temperature": 0.1,
      "prompt": "You are a software architect. Investigate the codebase, then produce a clear, step-by-step implementation plan. Reuse existing patterns and utilities. Propose changes; do not edit without confirmation.",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "formatter": {
    "prettier": {
      "disabled": false
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".turbo/**",
      ".cache/**",
      "coverage/**",
      ".venv/**",
      "__pycache__/**",
      ".git/**"
    ]
  },
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  },
  "keybinds": {
    "tool_details": "none",
    "help_show": "<leader>?"
  }
}
